{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/doctor.schema.json",
  "title": "DoctorArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": ["artifact", "schema", "completeness", "status", "checks", "summary"],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string" },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "doctor" },
    "schema": { "const": "doctor@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "status": { "enum": ["passed", "needs_attention", "failed"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "status", "summary"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": { "enum": ["runtime", "tooling", "filesystem", "schema", "artifact", "ci"] },
          "status": { "enum": ["pass", "warn", "fail", "skip"] },
          "summary": { "type": "string", "minLength": 1 },
          "observed": { "type": "string" },
          "remediation": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["checks", "passed", "warnings", "failed", "skipped"],
      "additionalProperties": false,
      "properties": {
        "checks": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    }
  }
}

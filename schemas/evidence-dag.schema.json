{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/evidence-dag.schema.json",
  "title": "EvidenceDagArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": ["artifact", "schema", "completeness", "nodes", "edges", "summary"],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string" },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "evidence-dag" },
    "schema": { "const": "evidence-dag@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": {
            "enum": ["requirement", "rule", "finding", "artifact", "verdict", "manual-test", "ci-run", "pr-comment-line"]
          },
          "label": { "type": "string" },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target", "type"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "target": { "type": "string" },
          "type": {
            "enum": [
              "satisfies",
              "generated_by",
              "evidenced_by",
              "gated_by",
              "exports_to",
              "requires_manual_oracle",
              "cites_artifact"
            ]
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["nodeCount", "edgeCount", "findings", "artifacts", "verdicts"],
      "additionalProperties": false,
      "properties": {
        "nodeCount": { "type": "integer", "minimum": 0 },
        "edgeCount": { "type": "integer", "minimum": 0 },
        "findings": { "type": "integer", "minimum": 0 },
        "artifacts": { "type": "integer", "minimum": 0 },
        "verdicts": { "type": "integer", "minimum": 0 }
      }
    }
  }
}

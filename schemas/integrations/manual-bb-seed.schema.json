{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/integrations/manual-bb-seed.schema.json",
  "title": "ManualBbSeed",
  "type": "object",
  "required": ["version", "producer", "run_id", "scope", "risk_seeds", "invariant_seeds", "test_seed_refs", "known_gaps", "oracle_gaps"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "ctg.manual-bb/v1" },
    "producer": { "const": "code-to-gate" },
    "run_id": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["repo", "changed_files", "affected_entrypoints"],
      "additionalProperties": false,
      "properties": {
        "repo": { "type": "string" },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "affected_entrypoints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "risk_seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "evidence", "suggested_test_intents"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "suggested_test_intents": { "type": "array", "items": { "enum": ["regression", "boundary", "negative", "abuse", "smoke", "compatibility"] } }
        }
      }
    },
    "invariant_seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "confidence", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "statement": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "test_seed_refs": { "type": "array", "items": { "type": "string" } },
    "known_gaps": { "type": "array", "items": { "type": "string" } },
    "oracle_gaps": { "type": "array", "items": { "type": "string" } }
  }
}
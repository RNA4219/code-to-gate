{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/schema-migration.schema.json",
  "title": "SchemaMigrationArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": [
    "artifact",
    "schema",
    "completeness",
    "status",
    "source",
    "target",
    "changes",
    "validation",
    "generated_by"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string", "minLength": 1 },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "schema-migration" },
    "schema": { "const": "schema-migration@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "status": { "enum": ["migrated", "unchanged", "failed"] },
    "source": { "$ref": "#/$defs/artifactRef" },
    "target": {
      "type": "object",
      "required": ["path", "version"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "artifact": { "type": "string", "minLength": 1 },
        "schema": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["status", "errors"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["ok", "error"] },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "generated_by": { "const": "ctg-schema-migrate-v1" }
  },
  "$defs": {
    "artifactRef": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "artifact": { "type": "string", "minLength": 1 },
        "schema": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    }
  }
}

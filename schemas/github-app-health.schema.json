{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/github-app-health.schema.json",
  "title": "GitHubAppHealthArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": [
    "artifact",
    "schema",
    "completeness",
    "status",
    "authMode",
    "repository",
    "pullRequest",
    "source",
    "publish",
    "permissions",
    "generated_by"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string", "minLength": 1 },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "github-app-health" },
    "schema": { "const": "github-app-health@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "status": { "enum": ["posted", "dry_run", "failed"] },
    "authMode": { "enum": ["github-token", "github-app", "none"] },
    "repository": {
      "type": "object",
      "required": ["owner", "repo"],
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 }
      }
    },
    "pullRequest": {
      "type": "object",
      "required": ["number"],
      "additionalProperties": false,
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "commitSha": { "type": "string", "minLength": 7 }
      }
    },
    "source": {
      "type": "object",
      "required": ["artifactDir", "markdownPath", "markdownHashSha256"],
      "additionalProperties": false,
      "properties": {
        "artifactDir": { "type": "string", "minLength": 1 },
        "markdownPath": { "type": "string", "minLength": 1 },
        "markdownHashSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "prReviewPath": { "type": "string", "minLength": 1 },
        "artifactUrl": { "type": "string", "minLength": 1 }
      }
    },
    "publish": {
      "type": "object",
      "required": ["action", "marker"],
      "additionalProperties": false,
      "properties": {
        "action": { "enum": ["created", "updated", "skipped", "failed"] },
        "commentId": { "type": "integer", "minimum": 1 },
        "marker": { "const": "code-to-gate PR Review" }
      }
    },
    "permissions": {
      "type": "object",
      "required": ["required", "checked"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "checked": { "type": "boolean" },
        "granted": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": { "enum": ["github-app-token", "github-token", "not-available"] }
      }
    },
    "rateLimit": {
      "type": "object",
      "required": ["checked", "resource", "limit", "remaining", "reset", "used"],
      "additionalProperties": false,
      "properties": {
        "checked": { "type": "boolean" },
        "resource": { "type": "string", "minLength": 1 },
        "limit": { "type": "integer", "minimum": 0 },
        "remaining": { "type": "integer", "minimum": 0 },
        "reset": { "type": "integer", "minimum": 0 },
        "used": { "type": "integer", "minimum": 0 }
      }
    },
    "error": { "type": "string", "minLength": 1 },
    "generated_by": { "const": "ctg-pr-review-publish-v1" }
  }
}

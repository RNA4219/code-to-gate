{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/redaction-profile.schema.json",
  "title": "RedactionProfileArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": [
    "artifact",
    "schema",
    "completeness",
    "profile",
    "summary",
    "generated_by"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string", "minLength": 1 },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "redaction-profile" },
    "schema": { "const": "redaction-profile@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "profile": { "$ref": "./shared-defs.schema.json#/$defs/redactionProfile" },
    "summary": { "$ref": "./shared-defs.schema.json#/$defs/redactionSummary" },
    "generated_by": { "const": "ctg-redaction-profile-v1" }
  }
}

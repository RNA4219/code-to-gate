{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/release-pack.schema.json",
  "title": "ReleasePackArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": ["artifact", "schema", "completeness", "status", "ci", "entries", "outputs", "summary"],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string" },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "release-pack" },
    "schema": { "const": "release-pack@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "status": { "enum": ["ready", "partial"] },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "provider": { "enum": ["github-actions", "manual"] },
        "runId": { "type": "string", "minLength": 1 }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "label", "kind", "present"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "role": {
            "enum": ["qeg", "audit", "diff", "readiness", "manual-bb", "ci", "artifact", "generated"]
          },
          "label": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["required", "optional", "generated"] },
          "present": { "type": "boolean" },
          "sourcePath": { "type": "string", "minLength": 1 },
          "packPath": { "type": "string", "minLength": 1 },
          "hashSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "schema": { "type": "string", "minLength": 1 },
          "sizeBytes": { "type": "integer", "minimum": 0 },
          "generatedAt": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
          "description": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["manifest", "html", "zip"],
      "additionalProperties": false,
      "properties": {
        "manifest": { "type": "string", "minLength": 1 },
        "html": { "type": "string", "minLength": 1 },
        "zip": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "requiredEvidence",
        "presentRequiredEvidence",
        "missingRequiredEvidence",
        "includedArtifacts",
        "findings",
        "qegSchemaChecks",
        "manualTestCandidates",
        "changedFiles"
      ],
      "additionalProperties": false,
      "properties": {
        "requiredEvidence": { "type": "integer", "minimum": 0 },
        "presentRequiredEvidence": { "type": "integer", "minimum": 0 },
        "missingRequiredEvidence": { "type": "integer", "minimum": 0 },
        "includedArtifacts": { "type": "integer", "minimum": 0 },
        "findings": { "type": "integer", "minimum": 0 },
        "readinessStatus": { "type": "string", "minLength": 1 },
        "qegSchemaChecks": { "type": "integer", "minimum": 0 },
        "manualTestCandidates": { "type": "integer", "minimum": 0 },
        "changedFiles": { "type": "integer", "minimum": 0 },
        "ciUrl": { "type": "string", "minLength": 1 }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/invariants.schema.json",
  "title": "InvariantsArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": ["artifact", "schema", "completeness", "invariants"],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string" },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "invariants" },
    "schema": { "const": "invariants@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "kind", "confidence", "sourceFindingIds", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "statement": { "type": "string" },
          "kind": { "enum": ["business", "technical", "security", "data", "api"] },
          "confidence": { "$ref": "./shared-defs.schema.json#/$defs/confidence" },
          "sourceFindingIds": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "./shared-defs.schema.json#/$defs/evidenceRef" } },
          "rationale": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}

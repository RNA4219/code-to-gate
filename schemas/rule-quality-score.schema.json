{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/rule-quality-score.schema.json",
  "title": "RuleQualityScoreArtifact",
  "allOf": [{ "$ref": "./shared-defs.schema.json#/$defs/artifactHeader" }],
  "required": [
    "artifact",
    "schema",
    "completeness",
    "subject",
    "scores",
    "formula",
    "inputEvidence",
    "summary",
    "generated_by"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "$ref": "./shared-defs.schema.json#/$defs/version" },
    "generated_at": { "$ref": "./shared-defs.schema.json#/$defs/isoDateTime" },
    "run_id": { "type": "string", "minLength": 1 },
    "repo": { "$ref": "./shared-defs.schema.json#/$defs/repoRef" },
    "tool": { "$ref": "./shared-defs.schema.json#/$defs/toolRef" },
    "artifact": { "const": "rule-quality-score" },
    "schema": { "const": "rule-quality-score@v1" },
    "completeness": { "$ref": "./shared-defs.schema.json#/$defs/completeness" },
    "subject": {
      "type": "object",
      "required": ["type", "id", "path"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["rule", "plugin"] },
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "scores": {
      "type": "object",
      "required": ["fixtureCoverage", "falsePositiveReview", "evidenceCompleteness", "schemaCompatibility", "runtimeCost"],
      "additionalProperties": false,
      "properties": {
        "fixtureCoverage": { "$ref": "#/$defs/metric" },
        "falsePositiveReview": { "$ref": "#/$defs/metric" },
        "evidenceCompleteness": { "$ref": "#/$defs/metric" },
        "schemaCompatibility": { "$ref": "#/$defs/metric" },
        "runtimeCost": { "$ref": "#/$defs/metric" }
      }
    },
    "formula": {
      "type": "object",
      "required": ["version", "weights"],
      "additionalProperties": false,
      "properties": {
        "version": { "const": "ctg-rule-quality-score-v1" },
        "weights": {
          "type": "object",
          "required": ["fixtureCoverage", "falsePositiveReview", "evidenceCompleteness", "schemaCompatibility", "runtimeCost"],
          "additionalProperties": false,
          "properties": {
            "fixtureCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
            "falsePositiveReview": { "type": "number", "minimum": 0, "maximum": 1 },
            "evidenceCompleteness": { "type": "number", "minimum": 0, "maximum": 1 },
            "schemaCompatibility": { "type": "number", "minimum": 0, "maximum": 1 },
            "runtimeCost": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "inputEvidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/inputEvidence" }
    },
    "summary": {
      "type": "object",
      "required": ["totalScore", "grade", "warnings"],
      "additionalProperties": false,
      "properties": {
        "totalScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "grade": { "enum": ["A", "B", "C", "D", "F"] },
        "warnings": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "generated_by": { "const": "ctg-rule-quality-score-v1" }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["score", "weight", "evidenceIds", "notes"],
      "additionalProperties": false,
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "inputEvidence": {
      "type": "object",
      "required": ["id", "path", "hashSha256", "kind", "sizeBytes"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "hashSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "kind": { "enum": ["manifest", "fixture", "test", "schema", "readme", "source", "score"] },
        "sizeBytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}

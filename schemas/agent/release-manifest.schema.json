{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/agent/release-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "tag",
    "commit",
    "package",
    "assets",
    "immutable",
    "provenance"
  ],
  "properties": {
    "schema": {
      "const": "ctg-release-manifest@v1"
    },
    "tag": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "sha256",
          "sha512",
          "byte_length"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "sha512": {
            "type": "string",
            "minLength": 1
          },
          "byte_length": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "immutable": {
      "const": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow",
        "run_id"
      ],
      "properties": {
        "workflow": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "attestation": {
      "type": "object"
    }
  }
}

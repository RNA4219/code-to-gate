{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-to-gate.local/schemas/agent/readiness-input.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo",
    "policy"
  ],
  "properties": {
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "out": {
      "type": "string",
      "minLength": 1
    },
    "baseline": {
      "type": "string",
      "minLength": 1
    },
    "manual_evidence": {
      "type": "string",
      "minLength": 1
    }
  }
}
